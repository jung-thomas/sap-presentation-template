{
  "name": "@jungsap/slidev-theme-sap",
  "version": "0.5.7",
  "description": "SAP-branded Slidev theme with Fiori Horizon look-and-feel",
  "type": "module",
  "main": "./index.ts",
  "exports": {
    ".": "./index.ts",
    "./vite-plugin": {
      "types": "./setup/vite-plugin.d.ts",
      "default": "./setup/vite-plugin.js"
    },
    "./styles/*": "./styles/*",
    "./layouts/*": "./layouts/*",
    "./components/*": "./components/*",
    "./presenters/*": "./presenters/*",
    "./teams/*": "./teams/*",
    "./programs/*": "./programs/*",
    "./snippets/*": "./snippets/*"
  },
  "files": [
    "index.ts",
    "types.ts",
    "yaml.d.ts",
    "style.css",
    "layouts",
    "components",
    "styles",
    "setup",
    "public",
    "presenters",
    "teams",
    "programs",
    "snippets"
  ],
  "slidev": {
    "colorSchema": "light",
    "highlighter": "shiki"
  },
  "peerDependencies": {
    "@slidev/cli": "^0.49.0",
    "@ui5/webcomponents": "^2.5.0",
    "@ui5/webcomponents-fiori": "^2.5.0",
    "qrcode": "^1.5.4",
    "vue": "^3.5.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
